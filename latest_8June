// mode:multi thumbnail tab — each pageCategories entry = its own accordion group
  // Preserves order from pageCategories array; same category can appear multiple times
  interface MultiPageGroup {
    catId:    string;
    pages:    number[];
    groupKey: string;   // unique: catId + position index
  }
  const multiPageGroups: MultiPageGroup[] = [];
  const OTHERS_KEY = '__others__';
  if (isMultiPage(mode) && activeDoc?.pageCategories) {
    // Track every page explicitly listed in any pageCategories entry
    const allListedPages = new Set<number>();
    activeDoc.pageCategories.forEach(pc => pc.pages.forEach(p => allListedPages.add(p)));

    // Build named category groups — entries with no category are skipped here
    // (their pages are already in allListedPages so they won't appear in Others)
    activeDoc.pageCategories.forEach((pc, idx) => {
      if (!pc.category) return; // no category → pages already captured in allListedPages
      multiPageGroups.push({
        catId:    pc.category,
        pages:    [...pc.pages],
        groupKey: `${pc.category}__${idx}`,
      });
    });

    // Build Others: any page from 1..totalPages not listed in any pageCategories entry.
    // Use store.pageCount (real loaded page count) so pages beyond the manifest range
    // are included. Fall back to max(listed pages) until the doc finishes loading.
    const totalPages = adPageCount > 0 ? adPageCount : (activeDoc.totalPages ?? 0);
    if (totalPages > 0) {
      const others: number[] = [];
      for (let p = 1; p <= totalPages; p++) {
        if (!allListedPages.has(p)) others.push(p);
      }
      if (others.length) {
        multiPageGroups.push({ catId: OTHERS_KEY, pages: others, groupKey: OTHERS_KEY });
      }
    }
  }


